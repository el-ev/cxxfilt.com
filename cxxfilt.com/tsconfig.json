{
  "compilerOptions": {
    "target": "es2020",
    "module": "es2022",
    "lib": ["es2020", "webworker"],
    "types": ["@cloudflare/workers-types"],
    "moduleResolution": "bundler",
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    "strict": true,
    "resolveJsonModule": true,
    "esModuleInterop": true
  },
  "include": ["src/**/*", "src/types.d.ts"]
}
